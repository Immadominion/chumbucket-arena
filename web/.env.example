# Public base URL — used for metadataBase / OG + Twitter share images.
# Set this to the deployed Chumbucket origin on Vercel.
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Live wiring — the Bun/tRPC backend origin (Railway). tRPC over HTTP + WS.
NEXT_PUBLIC_BACKEND_URL=https://chumbucket-arena-production.up.railway.app
# Privy app id — a public client identifier (the app *secret* lives only on the backend).
NEXT_PUBLIC_PRIVY_APP_ID=cmqn0pa6s00240djp985c7mp8

# Same Supabase project as the mobile app (chumbucket/.env) — shared users/friends
# tables, so an account is the same account on web and mobile. Anon key only
# (safe for client-side use); copy the real values from the mobile app's .env.
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Solana RPC used for building/sending peer-to-peer SOL transfers client-side.
# Matches the mobile app's SOLANA_RPC_URL — devnet during the hackathon.
NEXT_PUBLIC_SOLANA_RPC_URL=https://api.devnet.solana.com

# chumbucket_arena — the real, non-custodial on-chain escrow the Call/Claim
# screens stake into and pay out from directly (lib/arena-onchain.ts). Program
# id is baked into the vendored IDL; the mint here must match the deployed
# Config's usdc_mint (see onchain/gaffer_verifier/scripts/devnet-lifecycle/
# test-usdc-mint.json) — devnet test-USDC during the hackathon.
NEXT_PUBLIC_CHUMBUCKET_USDC_MINT=3r7XYUxoGZ57Fm91zbTw8GtmwCYzPV5CdmabqgDwtdhY
